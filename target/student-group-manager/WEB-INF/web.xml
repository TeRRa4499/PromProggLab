<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">

    <display-name>Student Group Manager</display-name>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>GroupsServlet</servlet-name>
        <servlet-class>ru.example.servlet.GroupsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GroupsServlet</servlet-name>
        <url-pattern>/groups</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteGroupServlet</servlet-name>
        <servlet-class>ru.example.servlet.DeleteGroupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteGroupServlet</servlet-name>
        <url-pattern>/groups/delete</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditGroupServlet</servlet-name>
        <servlet-class>ru.example.servlet.EditGroupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditGroupServlet</servlet-name>
        <url-pattern>/groups/edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SaveGroupServlet</servlet-name>
        <servlet-class>ru.example.servlet.SaveGroupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SaveGroupServlet</servlet-name>
        <url-pattern>/groups/save</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StudentsServlet</servlet-name>
        <servlet-class>ru.example.servlet.StudentsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentsServlet</servlet-name>
        <url-pattern>/students</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteStudentServlet</servlet-name>
        <servlet-class>ru.example.servlet.DeleteStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteStudentServlet</servlet-name>
        <url-pattern>/students/delete</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditStudentServlet</servlet-name>
        <servlet-class>ru.example.servlet.EditStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditStudentServlet</servlet-name>
        <url-pattern>/students/edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SaveStudentServlet</servlet-name>
        <servlet-class>ru.example.servlet.SaveStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SaveStudentServlet</servlet-name>
        <url-pattern>/students/save</url-pattern>
    </servlet-mapping>

</web-app>
