    </servlet>
    <servlet-mapping>
        <servlet-name>SaveGroupServlet</servlet-name>
        <url-pattern>/groups/save</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteGroupServlet</servlet-name>
        <servlet-class>ru.example.servlet.DeleteGroupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteGroupServlet</servlet-name>
        <url-pattern>/groups/delete</url-pattern>
